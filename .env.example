# MIRA reads .env from the workspace where you run `mira`.
# Copy this file to .env, then keep exactly one provider block active.

# Shared runtime settings
MIRA_TOOL_OUTPUT_CHARS=240
# MIRA_SESSION_DIR=.mira/_sessions

# Optional generation settings
# MIRA_LLM_TEMPERATURE=0.2
# MIRA_LLM_MAX_TOKENS=4096
# MIRA_LLM_TOP_P=0.95

# LM Studio, the default local provider
MIRA_LLM_PROVIDER=lmstudio
MIRA_LLM_MODEL=local-model
MIRA_LLM_BASE_URL=http://localhost:1234/v1
MIRA_LLM_API_KEY=lm-studio

# Ollama
# MIRA_LLM_PROVIDER=ollama
# MIRA_LLM_MODEL=llama3.1
# MIRA_LLM_BASE_URL=http://localhost:11434

# OpenAI
# MIRA_LLM_PROVIDER=openai
# MIRA_LLM_MODEL=gpt-4.1-mini
# MIRA_LLM_API_KEY=sk-...

# Anthropic / Claude
# MIRA_LLM_PROVIDER=anthropic
# MIRA_LLM_MODEL=claude-3-5-sonnet-latest
# MIRA_LLM_API_KEY=sk-ant-...

# Gemini
# MIRA_LLM_PROVIDER=gemini
# MIRA_LLM_MODEL=gemini-1.5-pro
# MIRA_LLM_API_KEY=...

# Groq
# MIRA_LLM_PROVIDER=groq
# MIRA_LLM_MODEL=llama-3.3-70b-versatile
# MIRA_LLM_API_KEY=gsk_...

# OpenRouter
# MIRA_LLM_PROVIDER=openrouter
# MIRA_LLM_MODEL=openai/gpt-4.1-mini
# MIRA_LLM_API_KEY=sk-or-...
